{
    "name": "gml/sistema-cameras",
    "description": "Sistema de Gerenciamento de Câmeras - GML",
    "type": "project",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "config/app.php",
            "config/database.php",
            "inc/security.php",
            "inc/single_session.php",
            "src/ErrorHandler.php",
            "src/Exceptions.php"
        ]
    },
    "scripts": {
        "test": "phpunit --do-not-cache-result",
        "lint": "find . -name '*.php' -not -path './vendor/*' -exec php -l {} \\;"
    }
}
