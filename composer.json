{
    "name": "gml/sistema-cameras",
    "description": "Sistema de Gerenciamento de Câmeras de Segurança",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "monolog/monolog": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7",
        "enlightn/security-checker": "^1.10"
    },
    "autoload": {
        "files": [
            "config/app.php",
            "config/database.php",
            "inc/security.php",
            "inc/single_session.php",
            "src/ErrorHandler.php",
            "src/Api/ApiResponse.php",
            "src/Api/RequestValidator.php",
            "src/Api/RateLimiter.php",
            "src/Services/EquipamentoService.php"
        ]
    },
    "scripts": {
        "test": "phpunit --do-not-cache-result",
        "lint": "find . -name '*.php' -not -path './vendor/*' -exec php -l {} \\;"
    },
    "config": {
        "disable-tls": true
    }
}
