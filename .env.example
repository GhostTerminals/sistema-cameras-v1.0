# ===================================================================
# EXEMPLO DE CONFIGURAÇÃO - NÃO USE EM PRODUÇÃO!
# ===================================================================
#
# ⚠️  INSTRUÇÕES IMPORTANTES:
#
# 1. NUNCA use este arquivo diretamente em produção
# 2. Copie .env.template para .env
# 3. Edite .env com valores reais e seguros
# 4. NUNCA commite .env no Git (já está em .gitignore)
# 5. Se commitou por acaso, execute:
#    git rm --cached .env
#    git commit -m "Remove .env from tracking"
#
# ===================================================================

# Ambiente
# Valores: development, testing, production
# IMPORTANTE: Altere para production antes de deployar
CAMERAS_ENV=development

# Banco de Dados - ALTERAR EM .env!
DB_HOST=db
DB_NAME=cftv_gml
DB_USER=cftv_user
DB_PASS=__DEFINA_UMA_SENHA_FORTE_AQUI__

# Proxy Confiavel (se usar reverse proxy como Nginx)
# Lista de IPs separados por virgula. Deixe vazio se nao usar proxy.
PROXY_TRUSTED_IPS=

# Origens permitidas para CORS (se necessario)
# Lista separada por virgula. Deixe vazio para same-origin only.
APP_ALLOWED_ORIGINS=

# Aplicacao
APP_TIMEZONE=America/Sao_Paulo
APP_NAME=Sistema de Cameras e Alarmes

# Sessao (em segundos)
CAMERAS_SESSION_TIMEOUT=3600
CAMERAS_SESSION_ABSOLUTE_TIMEOUT=28800

# CSP - Content Security Policy
# 1 = permite inline styles (Bootstrap)
# 0 = strict CSP (recomendado para producao)
CAMERAS_CSP_ALLOW_INLINE_STYLES=0

# Porta da aplicacao (use reverse proxy com TLS em producao)
APP_PORT=8080
