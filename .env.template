# ===================================================================
# Environment Template - COPIE PARA .env E CONFIGURE
# ===================================================================
#
# IMPORTANTE: 
# - Nunca commite .env no repositório Git
# - Copie este arquivo para .env em cada ambiente
# - Substitua os valores "CHANGE_ME_*" por valores reais e seguros
# - Para gerar senhas: openssl rand -base64 32
#
# ===================================================================

# Ambiente
# Valores: development, testing, production
CAMERAS_ENV=development

# Banco de Dados - CONFIGURE AQUI
DB_HOST=localhost
DB_NAME=cftv_gml
DB_USER=CHANGE_ME_DB_USER
DB_PASS=CHANGE_ME_DB_PASS_32_CHARS_MIN
MYSQL_ROOT_PASS=CHANGE_ME_ROOT_PASS_32_CHARS_MIN

# Aplicação
APP_TIMEZONE=America/Sao_Paulo
APP_NAME=Sistema de Cameras e Alarmes

# Sessão (em segundos)
CAMERAS_SESSION_TIMEOUT=3600
CAMERAS_SESSION_ABSOLUTE_TIMEOUT=28800

# CSP - Content Security Policy
# 1 = permite inline styles (Bootstrap)
# 0 = strict CSP (recomendado para produção)
CAMERAS_CSP_ALLOW_INLINE_STYLES=0

# Porta da aplicação (apenas se não usar reverse proxy)
APP_PORT=80
